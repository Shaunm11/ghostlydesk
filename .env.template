# GhostlyDesk — Environment Configuration
# Copy this file to .env and fill in your values

# GoHighLevel API
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here

# Server
PORT=3000

# GHL Webhook URL — fired when a wishlist match is found
# Leave blank to disable webhooks (wishlist matching still works locally)
GHL_WEBHOOK_URL=
